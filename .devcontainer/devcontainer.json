{
  "name": "Career Copilot",

  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },

  "postCreateCommand": "pip install -r requirements.txt",

  "portsAttributes": {
    "8501": {
      "label": "Career Copilot",
      "onAutoForward": "openPreview"
    }
  },

  "forwardPorts": [
    8501
  ]
}